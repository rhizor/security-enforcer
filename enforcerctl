#!/bin/bash
# ─────────────────────────────────────────────────────────
# enforcerctl - Controlador CLI para el enforcer
# Uso: ./enforcerctl [status|run|dry-run|list-rules|clear]
# ─────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENFORCER="$SCRIPT_DIR/enforcer.py"
CONFIG="$SCRIPT_DIR/config.json"

case "$1" in
    status)
        echo "📊 Estado del Enforcer"
        echo "======================="
        if [ -f "$SCRIPT_DIR/.enforcer_state.json" ]; then
            python3 -c "
import json
with open('$SCRIPT_DIR/.enforcer_state.json') as f:
    data = json.load(f)
print(f\"Última ejecución: {data['last_run']}\")
print(f\"CVEs procesados: {len(data.get('cves', []))}\")
print(f\"Ataques detectados: {len(data.get('attacks', []))}\")
print(f\"Reglas generadas: {len(data.get('rules', []))}\")
"
        else
            echo "Sin ejecuciones previas"
        fi
        ;;
        
    run)
        echo "🚀 Ejecutando enforcer en modo producción..."
        python3 -c "
import json
with open('$CONFIG') as f:
    c = json.load(f)
c['dry_run'] = False
with open('$CONFIG', 'w') as f:
    json.dump(c, f, indent=2)
"
        python3 "$ENFORCER"
        ;;
        
    dry-run)
        echo "🔍 Ejecutando en modo dry-run..."
        python3 -c "
import json
with open('$CONFIG') as f:
    c = json.load(f)
c['dry_run'] = True
with open('$CONFIG', 'w') as f:
    json.dump(c, f, indent=2)
"
        python3 "$ENFORCER"
        ;;
        
    list-rules)
        echo "📋 Reglas activas en nftables:"
        sudo nft -a list ruleset 2>/dev/null | grep -A2 "filter" || echo "nftables no disponible"
        ;;
        
    clear)
        echo "🧹 Limpiando estado..."
        rm -f "$SCRIPT_DIR/.enforcer_state.json"
        echo "Estado limpiado"
        ;;
        
    *)
        echo "Usage: $0 {status|run|dry-run|list-rules|clear}"
        exit 1
        ;;
esac
